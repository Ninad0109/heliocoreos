[Unit]
Description=HelioCore OS Boot System
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/pi/heliocoreos
ExecStart=/usr/bin/python3 /home/pi/heliocoreos/core/init.py
StandardInput=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
Restart=no

[Install]
WantedBy=multi-user.target
